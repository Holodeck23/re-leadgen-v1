# Google Sheets (CRM)
# Create a service account: https://console.cloud.google.com → IAM → Service Accounts
# Download the JSON key file. Share the sheet with the service account email.
GOOGLE_SHEETS_KEY_FILE=/path/to/service-account.json
LEAD_SHEET_ID=your-google-sheet-id-from-url

# Meta Ads (fallback script — the main path uses Pipeboard MCP)
# Only needed if MCP is unavailable (e.g. cron without Claude session)
META_ACCESS_TOKEN=your-meta-graph-api-token
META_AD_ACCOUNT_ID=act_1234567890

# Claude Code (for headless loop-runner.sh)
ANTHROPIC_API_KEY=sk-ant-your-key-here
